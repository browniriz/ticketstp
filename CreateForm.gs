/**
 * Ticketsbot — создание чек-листа тестирования в Google Forms.
 * Запустить один раз: выбрать функцию createTestingChecklist → Run.
 * Ссылки на форму появятся в Logs (View → Logs).
 */
function createTestingChecklist() {
  var form = FormApp.create('Чек-лист тестирования Ticketsbot');
  form.setDescription('Заполняется администратором при каждом тестировании бота.');
  form.setCollectEmail(false);
  form.setShowLinkToRespondAgain(true);

  // ---------- Метаданные ----------
  form.addTextItem()
    .setTitle('Дата тестирования')
    .setRequired(true);
  form.addTextItem()
    .setTitle('Имя тестировщика')
    .setRequired(true);
  form.addTextItem()
    .setTitle('Версия / сборка (необязательно)')
    .setRequired(false);

  var CHOICES = ['✅ Пройдено', '❌ Не пройдено'];

  function addItem(title) {
    form.addMultipleChoiceItem()
      .setTitle(title)
      .setChoiceValues(CHOICES)
      .setRequired(false);
    form.addTextItem()
      .setTitle('Комментарий')
      .setRequired(false);
  }

  // ============================================================
  // 1. Вход и интерфейс
  // ============================================================
  addItem('1. Вход — заголовок «Панель заявок», подпись «Режим: Администратор»');
  addItem('1. Видны четыре вкладки: Заявки · История · Доступы · Создать');
  addItem('1. Кнопка 🌙/☀️ переключает тему, при повторном открытии тема сохранилась');

  // ============================================================
  // 2. Создание заявки — типы и города
  // ============================================================
  addItem('2. В списке «Тип заявки» вижу: Ломбард, Скупка, Касса, Ошибка, Перемещение, Оприходование, ТП');
  addItem('2. В списке городов вижу все стандартные города + «ТП» в конце');
  addItem('2. Выбираю город «ТП» → в офисах появляется только «ТП»');
  addItem('2. Создаю заявку тип «ТП» / город «ТП» / офис «ТП» — заявка создана, уведомление в группу пришло');
  addItem('2. Кнопка «Отправить» неактивна, пока не заполнены все поля');
  addItem('2. Выбираю город → офисы подгружаются, кнопка офиса разблокируется');
  addItem('2. Создаю заявку без вложения — создаётся успешно');
  addItem('2. Прикрепляю фото — вижу миниатюру, надпись меняется на «Файл прикреплён»');
  addItem('2. Прикрепляю PDF/Word — вижу имя файла в виде чипа');
  addItem('2. Файл >20 МБ — ошибка «Файл больше 20 МБ»');
  addItem('2. Файл .exe / .html — ошибка «Такой тип файла нельзя прикреплять»');
  addItem('2. После отправки появляется тост с номером заявки');

  // ============================================================
  // 3. Активные заявки
  // ============================================================
  addItem('3. Созданная заявка появилась в списке со статусом 🔴 Создана');
  addItem('3. У заявки «В работе» тикает живой таймер прямо на карточке');
  addItem('3. Значок 📎 виден на карточках с вложением');
  addItem('3. Список обновляется автоматически каждые 4 секунды');
  addItem('3. Шторка выезжает снизу, все поля заполнены верно');
  addItem('3. Тап на затемнённый фон закрывает шторку');
  addItem('3. Миниатюра изображения отображается в карточке');
  addItem('3. Тап по миниатюре → открывается лайтбокс с увеличенным фото внутри приложения');
  addItem('3. Тап на фон лайтбокса — закрывается');
  addItem('3. Кнопка ✕ — закрывает лайтбокс');
  addItem('3. Ссылка «Открыть файл» ведёт в Drive');
  addItem('3. Для PDF/Word миниатюра не показывается, только чип «Открыть файл»');

  // ============================================================
  // 4. Действия с заявкой
  // ============================================================
  addItem('4. Взять в работу — статус «В работе», таймер запустился, имя исполнителя появилось');
  addItem('4. Уведомление 🟡 «взята в работу» пришло в группу');
  addItem('4. Пауза — таймер остановился, накопленное время зафиксировано');
  addItem('4. Продолжить — таймер пошёл с того же места');
  addItem('4. Уведомление 🟡 «снова в работе» пришло в группу');
  addItem('4. Кнопка «Прикрепить файл» / «Заменить файл» в детали работает');
  addItem('4. Передать — загружается список других администраторов');
  addItem('4. Передача подтверждена — уведомление в группу, получатель получил DM');
  addItem('4. На доработку — без основания не отправляет');
  addItem('4. На доработку — заполняю основание, статус «На доработке», таймер остановлен');
  addItem('4. Создатель заявки получил DM с основанием');
  addItem('4. Уведомление о доработке пришло в группу');
  addItem('4. Завершить — статус «Решена», заявка ушла в «Историю»');
  addItem('4. Уведомление 🟢 с итоговым временем пришло в группу');
  addItem('4. Отклонить — без основания не отправляет');
  addItem('4. Отклонить — заполняю основание, статус «Отклонена», заявка ушла в «Историю»');
  addItem('4. Создатель получил DM с причиной отклонения');

  // ============================================================
  // 5. История
  // ============================================================
  addItem('5. История содержит только решённые и отклонённые заявки');
  addItem('5. У решённых отображается итоговое время и дата решения');
  addItem('5. У отклонённых виден красный блок с причиной');

  // ============================================================
  // 6. Проверка со стороны сотрудника
  // ============================================================
  addItem('6. Вкладки сотрудника: только «Новая заявка» и «Мои заявки»');
  addItem('6. Тип «ТП» не виден в списке типов у сотрудника');
  addItem('6. Город «ТП» не виден в списке городов у сотрудника');
  addItem('6. Тип «Оприходование» виден и доступен сотруднику');
  addItem('6. Сотрудник создаёт заявку — она появляется в «Мои заявки»');
  addItem('6. Заявка «На доработке» открывает форму редактирования с основанием');
  addItem('6. Все поля доступны для правки');
  addItem('6. «Отправить снова» — статус меняется на «Исправлена»');
  addItem('6. В аккаунте администратора заявка «Исправлена» видна, можно взять в работу');

  // ============================================================
  // 7. Управление доступами
  // ============================================================
  addItem('7. Видны разделы «Запросы» и «Сотрудники с доступом»');
  addItem('7. Одобрить запрос — сотрудник в списке, получил DM');
  addItem('7. Отклонить запрос — запись удалена, пользователь получил DM');
  addItem('7. Переименовать — поле ввода появляется, опрос останавливается');
  addItem('7. Сохранить имя — имя обновилось, опрос возобновился');
  addItem('7. Отмена переименования — список без изменений');
  addItem('7. Закрыть доступ — сотрудник удалён из списка, получил DM');
  addItem('7. Обновить ники — подтягивает @username из Telegram');

  // ============================================================
  // 8. Уведомления
  // ============================================================
  addItem('8. Новая заявка 🔴 — уведомление в группу');
  addItem('8. Взята в работу 🟡 — уведомление в группу');
  addItem('8. Решена 🟢 — уведомление в группу');
  addItem('8. На доработку ✏️ — уведомление в группу + DM сотруднику');
  addItem('8. Отклонена 🚫 — уведомление в группу + DM сотруднику');
  addItem('8. Передача 🔁 — уведомление в группу + DM получателю');
  addItem('8. Доступ одобрен — DM сотруднику');
  addItem('8. Доступ отклонён — DM сотруднику');
  addItem('8. Доступ закрыт — DM сотруднику');

  // ---------- Итог ----------
  form.addMultipleChoiceItem()
    .setTitle('Общий результат тестирования')
    .setChoiceValues(['✅ Всё работает', '⚠️ Есть замечания', '❌ Найдены блокирующие ошибки'])
    .setRequired(true);
  form.addParagraphTextItem()
    .setTitle('Общие замечания и найденные ошибки')
    .setRequired(false);

  // ---------- Лог ссылок ----------
  Logger.log('=== Форма создана ===');
  Logger.log('Редактировать: ' + form.getEditUrl());
  Logger.log('Заполнить:     ' + form.getPublishedUrl());
}
